{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@reesi/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@reesi/shared/*": [
        "../../packages/shared/src/*"
      ]
    },
    "baseUrl": ".",
    "allowJs": true,
    "noEmit": true
  },
  "include": [
    "next-env.d.ts",
    "src/**/*",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
